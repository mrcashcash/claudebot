TELEGRAM_BOT_TOKEN=123456:abc...
ALLOWED_TELEGRAM_USER_IDS=123456789

# Workspace = Claude's cwd. Default is the gateway folder itself.
CLAUDE_WORKSPACE_DIR=D:\claudebot

# Permission mode controls when canUseTool prompts you in Telegram:
#   default            — prompt for every non-read tool (most strict)
#   acceptEdits        — auto-allow Read/Write/Edit, prompt only for Bash etc.
#   bypassPermissions  — never prompt, run everything (most permissive)
#   plan               — Claude plans only, no execution
CLAUDE_PERMISSION_MODE=acceptEdits

# Auth: leave blank to use your existing `claude` login on this machine
# (~/.claude/.credentials.json). Only set this if the gateway can't read
# that file (different OS user, container, scheduled task, etc.).
# Generate with: claude setup-token
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# --- Voice transcription (local, no cloud) ---------------------------------
# Telegram voice + audio messages are transcribed on this machine. The
# bot prefers whisper.cpp (via the optional `nodejs-whisper` dependency)
# when the native build is available on this host, and falls back to
# transformers.js (ONNX, no toolchain required) otherwise. The selected
# backend is logged on first use. The first voice message after install
# pauses briefly while the model + backend are warmed up.

# Master toggle. Set to false to ignore voice/audio messages entirely.
VOICE_ENABLED=true

# Whisper model. Bigger = more accurate, slower, more disk/RAM.
#   tiny.en  (~75 MB, fastest, English-only)
#   base.en  (~140 MB, recommended for English) ← default
#   small.en (~460 MB)
#   medium.en (~1.5 GB)
#   tiny / base / small / medium / large / large-v3-turbo (multilingual)
WHISPER_MODEL=base.en

# Language hint (ISO 639-1, e.g. "en", "he", "es"). Leave blank or "auto"
# for auto-detect. Setting this is faster + more accurate when you only
# speak one language to the bot.
WHISPER_LANGUAGE=en

# If true, downloads the Whisper model at startup so the first voice
# message doesn't pay the download wait. False = lazy on first use.
WHISPER_PRELOAD=false

# Reject voice/audio messages longer than this (seconds). Whisper.cpp on a
# CPU-only machine gets slow on long clips with the bigger models.
VOICE_MAX_DURATION_SEC=600

# Override the bundled ffmpeg-static binary. Leave blank to use the one
# npm installs alongside this project. Set to e.g. "C:\\ffmpeg\\bin\\ffmpeg.exe"
# if the bundled binary fails to install (rare, mostly locked-down corp Windows).
# FFMPEG_PATH=
