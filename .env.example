TELEGRAM_BOT_TOKEN=123456:abc...
ALLOWED_TELEGRAM_USER_IDS=123456789

# Auth: leave blank to use your existing `claude` login on this machine
# (~/.claude/.credentials.json). Only set this if the gateway can't read
# that file (different OS user, container, scheduled task, etc.).
# Generate with: claude setup-token
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# --- Per-user app config ----------------------------------------------------
# Behavior settings (workspace, permission mode, model, voice, tz) live in
# `data/users/<your-telegram-id>.json` and are auto-created from
# `userTemplate.json` on the user's first message. Edit by hand or ask
# Claude to edit the file from inside the chat — the bot watches the
# directory and the next turn picks up the change without a restart.
#
# Removing the file does NOT revoke access; auth is gated by
# ALLOWED_TELEGRAM_USER_IDS above. Drop a user from that env var to
# revoke. Their JSON file can stay on disk for future re-add.

# Zapier MCP and other OAuth-based remote MCP servers are configured via
# the Claude CLI, not env vars — the bot's SDK inherits any user-scope
# servers from ~/.claude.json. To add Zapier:
#   claude mcp add --transport http --scope user zapier https://mcp.zapier.com/api/v1/connect
#   claude          # then /mcp → zapier → Authenticate (OAuth in browser)
#
# Google Calendar: when a calendar MCP is registered the same way, the
# bot's per-turn system prompt tells Claude to mirror meeting/appointment
# reminders into the calendar (in addition to scheduling the cron). Weather
# updates and other data-pull crons stay cron-only. If no calendar MCP is
# loaded, Claude just creates the cron silently — no error, no mention.
